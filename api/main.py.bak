@app.get("/api/trading/status")
async def get_trading_status(user=Depends(get_user)):
    """合并 status + stats，一次 Binance 调用"""
    import sys, os
    sys.path.insert(0, os.path.join(os.path.dirname(__file__), ".."))
    from shared.db import get_conn

    # Binance key 没配时返回占位数据
    import os
    if not os.getenv("BINANCE_API_KEY"):
        return {
            "balance": 0,
            "total_trades": 0,
            "positions": [],
            "recent_trades": [],
            "total_pnl": 0,
            "realized_pnl": 0,
            "current_positions": 0,
            "total_opens": 0,
            "total_closed": 0,
            "win_count": 0,
            "loss_count": 0,
            "win_rate": 0,
            "profit_ratio": 0,
            "profit_ratio_raw": 0,
            "max_drawdown": 0,
            "avg_win": 0,
            "avg_loss": 0,
            "best_trade": 0,
            "worst_trade": 0,
            "consecutive_wins": 0,
            "consecutive_losses": 0,
            "current_streak": 0,
            "reason_stats": {},
            "avg_holding_hours": 0,
            "avg_bars_held": 0,
        }

    EXCLUDED_REASONS = ("historical_import", "历史补录(手动平仓)")

    from trader.exchange import BinanceFutures
    from trader.config import TRADING_CONFIG
    INITIAL_CAPITAL = TRADING_CONFIG.get("total_capital", 5000)
    ex = BinanceFutures()
    try:
        margin_data = ex.get_margin_balance()
        balance = margin_data["totalWalletBalance"]
        positions = ex.get_positions()
        conn = get_conn()
        recent_trades = conn.execute(
            "SELECT * FROM trades WHERE exit_reason NOT IN ('historical_import','历史补录(手动平仓)') ORDER BY entry_time DESC LIMIT 15"
        ).fetchall()
        total_trades = conn.execute("SELECT COUNT(*) FROM trades WHERE exit_reason NOT IN ('historical_import','历史补录(手动平仓)')").fetchone()[0]
        
        # ---- stats 数据 ----
        closed = conn.execute(
            "SELECT pnl, pnl_pct, exit_reason, entry_time, exit_time FROM trades WHERE exit_time != 'N/A' AND exit_time IS NOT NULL AND exit_reason NOT IN ('historical_import','历史补录(手动平仓)')"
        ).fetchall()
        total_closed = len(closed)
        total_pnl = sum(r["pnl"] or 0 for r in closed)
        wins = [r for r in closed if (r["pnl"] or 0) > 0]
        losses = [r for r in closed if (r["pnl"] or 0) <= 0]
        win_count = len(wins)
        loss_count = len(losses)
        win_rate = round(win_count / total_closed * 100, 2) if total_closed else 0
        total_win_val = sum(r["pnl"] or 0 for r in wins)
        total_loss_val = abs(sum(r["pnl"] or 0 for r in losses))
        profit_ratio = round(abs(total_win_val / total_loss_val), 2) if total_loss_val else 0
        
        reason_stats = {}
        for r in closed:
            reason = r["exit_reason"] or "未知"
            if reason not in reason_stats:
                reason_stats[reason] = {"count": 0, "total_pnl": 0, "wins": 0}
            reason_stats[reason]["count"] += 1
            reason_stats[reason]["total_pnl"] += r["pnl"] or 0
            if (r["pnl"] or 0) > 0:
                reason_stats[reason]["wins"] += 1

        return {
            "balance": balance,
            "total_trades": total_trades,
            "positions": [
                {
                    "symbol": p["symbol"], "side": p["side"],
                    "quantity": p["quantity"], "entry_price": p["entry_price"],
                    "mark_price": p["mark_price"],
                    "unrealized_pnl": p["unrealized_pnl"],
                    "leverage": p["leverage"],
                    "margin": round(p["entry_price"] * p["quantity"] / p["leverage"], 2) if p["entry_price"] and p["leverage"] else 0,
                    "pnl_pct": round(p["unrealized_pnl"] / (p["entry_price"] * p["quantity"] / p["leverage"]) * 100, 2) if p["entry_price"] and p["leverage"] else 0,
                    "invested": round(p["entry_price"] * p["quantity"], 2),
                }
                for p in positions
            ],
            "recent_trades": [
                {
                    "symbol": t["symbol"], "side": t["side"],
                    "qty": t["quantity"],
                    "entry_price": t["entry_price"], "exit_price": t["exit_price"],
                    "pnl": t["pnl"], "pnl_pct": t["pnl_pct"],
                    "exit_reason": t["exit_reason"],
                    "entry_time": t["entry_time"], "exit_time": t["exit_time"],
                    "grade_at_entry": t["grade_at_entry"], "score_at_entry": t["score_at_entry"],
                }
                for t in recent_trades
            ],
            # stats 字段
            "total_pnl": round(balance - INITIAL_CAPITAL, 2) if isinstance(balance, (int, float)) else 0,
            "trades_pnl": round(total_pnl, 2),
            "income_pnl": round(conn.execute("SELECT SUM(pnl) FROM trades WHERE source='income_auto'").fetchone()[0] or 0, 2),
            "current_positions": len(positions),
            "total_opens": total_trades,
            "total_closed": total_closed,
            "win_count": win_count,
            "loss_count": loss_count,
            "win_rate": win_rate,
            "profit_ratio": profit_ratio,
            "reason_stats": {
                k: {
                    "count": v["count"],
                    "total_pnl": round(v["total_pnl"], 2),
                    "win_rate": round(v["wins"] / v["count"] * 100, 1) if v["count"] else 0,
                }
                for k, v in sorted(reason_stats.items(), key=lambda x: -x[1]["count"])
            },
        }
    except Exception as e:
        return {"error": str(e), "balance": 0, "positions": [], "recent_trades": [], "total_pnl": 0}
    finally:
        ex.close()


@app.get("/api/trading/stats")
async def get_trading_stats(user=Depends(get_user)):
    from shared.db import get_conn
    conn = get_conn()
    try:
        EXCL = ("historical_import", "历史补录(手动平仓)")
        # 所有已平仓交易（排除历史导入）
        closed = conn.execute(
            "SELECT pnl, pnl_pct, exit_reason, entry_time, exit_time FROM trades WHERE exit_time != 'N/A' AND exit_time IS NOT NULL AND exit_reason NOT IN (?,?)",
            EXCL
        ).fetchall()
        
        total_closed = len(closed)
        total_pnl = sum(r["pnl"] or 0 for r in closed)
        wins = [r for r in closed if (r["pnl"] or 0) > 0]
        losses = [r for r in closed if (r["pnl"] or 0) <= 0]
        win_count = len(wins)
        loss_count = len(losses)
        win_rate = round(win_count / total_closed * 100, 2) if total_closed else 0
        
        # 盈亏比
        total_win = sum(r["pnl"] or 0 for r in wins)
        total_loss = abs(sum(r["pnl"] or 0 for r in losses))
        profit_ratio = round(abs(total_win / total_loss), 2) if total_loss else 0
        
        # 当前持仓数
        import sys, os
        sys.path.insert(0, os.path.join(os.path.dirname(__file__), ".."))
        from trader.exchange import BinanceFutures
        ex = BinanceFutures()
        pos = ex.get_positions()
        current_pos = len(pos)
        ex.close()
        
        # 按平仓原因统计
        reason_stats = {}
        for r in closed:
            reason = r["exit_reason"] or "未知"
            if reason not in reason_stats:
                reason_stats[reason] = {"count": 0, "total_pnl": 0, "wins": 0}
            reason_stats[reason]["count"] += 1
            reason_stats[reason]["total_pnl"] += r["pnl"] or 0
            if (r["pnl"] or 0) > 0:
                reason_stats[reason]["wins"] += 1
        
        # 总开仓次数（排除历史导入）
        total_opens = conn.execute("SELECT count(*) FROM trades WHERE exit_reason NOT IN (?,?)", EXCL).fetchone()[0]
        
        return {
            "total_pnl": round(total_pnl, 2),
            "realized_pnl": round(total_pnl, 2),
            "current_positions": current_pos,
            "total_opens": total_opens,
            "total_closed": total_closed,
            "win_count": win_count,
            "loss_count": loss_count,
            "win_rate": win_rate,
            "profit_ratio": profit_ratio,
            "reason_stats": {
                k: {
                    "count": v["count"],
                    "total_pnl": round(v["total_pnl"], 2),
                    "win_rate": round(v["wins"] / v["count"] * 100, 1) if v["count"] else 0,
                }
                for k, v in sorted(reason_stats.items(), key=lambda x: -x[1]["count"])
            },
        }
    except Exception as e:
        return {"error": str(e), "total_pnl": 0, "current_positions": 0, "total_opens": 0}
    finally:
        pass


@app.get("/api/trading/history")
async def get_trading_history(page: int = 1, limit: int = 20, user=Depends(get_user)):
    from shared.db import get_conn
    conn = get_conn()
    try:
        offset = (page - 1) * limit
        EXCL = ("historical_import", "历史补录(手动平仓)")
        rows = conn.execute(
            "SELECT * FROM trades WHERE exit_reason NOT IN ('historical_import','历史补录(手动平仓)') ORDER BY entry_time DESC LIMIT ? OFFSET ?",
            (limit, offset)
        ).fetchall()
        total = conn.execute("SELECT count(*) FROM trades WHERE exit_reason NOT IN ('historical_import','历史补录(手动平仓)')").fetchone()[0]
        return {
            "total": total,
            "page": page,
            "trades": [
                {
                    "symbol": t["symbol"], "side": t["side"],
                    "qty": t["quantity"],
                    "entry_price": t["entry_price"], "exit_price": t["exit_price"],
                    "pnl": t["pnl"], "pnl_pct": t["pnl_pct"],
                    "exit_reason": t["exit_reason"],
                    "entry_time": t["entry_time"], "exit_time": t["exit_time"],
                    "grade_at_entry": t["grade_at_entry"], "score_at_entry": t["score_at_entry"],
                }
                for t in rows
            ],
        }
    except Exception as e:
        return {"error": str(e), "trades": []}
    finally:
        pass
